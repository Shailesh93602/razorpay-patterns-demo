# Razorpay test-mode credentials.
# Get these from Razorpay Dashboard → Settings → API Keys → Generate Test Key.
# Save the Key Secret — Razorpay displays it only once.
RAZORPAY_KEY_ID="rzp_test_XXXXXXXXXXXXXX"
RAZORPAY_KEY_SECRET="your-test-key-secret"
# Exposed to the browser so the Checkout.js modal on /demo knows which
# key to use. Should match RAZORPAY_KEY_ID (test mode uses rzp_test_*).
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_XXXXXXXXXXXXXX"

# Webhook signing secret.
# Set this AFTER deploying: Razorpay Dashboard → Settings → Webhooks → Add
# New Webhook → URL = https://<your-deploy>/api/webhook → generate secret.
RAZORPAY_WEBHOOK_SECRET="your-webhook-secret"

# Redis URL for the SETNX idempotency store. Upstash (free tier) works on
# Vercel; any redis:// URL works locally.
REDIS_URL="redis://localhost:6379"

# Optional — controls verbosity of server logs.
NODE_ENV="development"
